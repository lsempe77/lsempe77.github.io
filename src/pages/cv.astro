---
import Layout from '../layouts/Layout.astro';

const experience = [
  {
    period: "2024 – Present",
    title: "Senior Evaluation Specialist",
    organization: "International Initiative for Impact Evaluation (3ie)",
    description: "Leading impact evaluations and evidence synthesis projects across health, education, and social protection sectors. Managing RCC projects on AI in agriculture, evidence-informed policymaking, and health financing."
  },
  {
    period: "2023 – Present",
    title: "Visiting Fellow",
    organization: "University of Oxford, Department of Psychiatry",
    description: "Research on AI safety for mental health applications, therapeutic persona monitoring, and activation-level drift detection in LLM-based interventions."
  },
  {
    period: "2022 – 2024",
    title: "Research Fellow",
    organization: "Queen Margaret University",
    description: "Research on health systems, older people care, REDRESS project on NTDs and mental health in Liberia, and education policy in Latin America and Africa."
  },
  {
    period: "2017 – 2021",
    title: "Research Assistant / Research Associate",
    organization: "University of East Anglia",
    description: "REDRESS Project (NTDs and mental health in Liberia), UNHCR refugee integration research, COVID-19 research on older people and vaccination policies. PhD research on school-level inequality."
  },
  {
    period: "2014 – 2015",
    title: "Researcher",
    organization: "Centro de Investigación de la Universidad del Pacífico",
    description: "Research on education indicators and policy analysis for Peru's education sector."
  },
  {
    period: "2013 – 2014",
    title: "Director, Performance-Based Budgetary Programme",
    organization: "Ministry of Education, Peru",
    description: "Responsible for performance-based budgetary programme for basic education (£2 billion, 55% of national education spending). Led results-based budgeting reforms, teacher training programs, and school governance systems."
  },
  {
    period: "2012 – 2013",
    title: "Rural Housing Programme Director",
    organization: "Ministry of Housing, Construction and Sanitation, Peru",
    description: "Political representative for Regional Governments. Led construction of 215 community centres (Tambos) serving indigenous populations in remote areas."
  },
  {
    period: "2000 – 2012",
    title: "Program Director",
    organization: "Asociación Civil Solidaridad en Marcha",
    description: "Coordinated five thousand volunteers across Peru, Brazil, Colombia, Costa Rica, and Ecuador. Fundraising for primary care clinics, schools, and rural housing."
  }
];

const teaching = [
  "Impact Evaluation in R (Abu Dhabi Government)",
  "Quantitative Evidence for Development (University of East Anglia)",
  "Econometric Methods for Development (University of East Anglia)",
  "Educational Assessment (University of East Anglia)",
  "Programme Evaluation (Queen Margaret University)",
  "Performance-Based Public Budgeting (Universidad Católica San Pablo)",
  "Monitoring and Evaluation in Public Policy (Universidad Católica San Pablo)",
  "Principles of Epidemiology and Research Techniques (University of East Anglia)"
];

const training = [
  "Intermediate Qualitative Comparative Analysis (by Carsten Q. Schneider and Ioana-Elena Oana)",
  "Advanced Doctoral Training on Quantitative Methods and Analysis (by Roberta Fida)"
];

const service = [
  "Co-Director, Global Platform for Coronavirus and Older People",
  "OECD Evidence Web for Education Expert Group",
  "Sociedad Peruana de Investigación Educativa (SIEP), Board Member",
  "Educationis Momentum, Board Member",
  "Revista Peruana de Investigación Educativa: Co-editor (2020-2021; 2025-present)",
  "Peer reviewer: Journal of Development Effectiveness, BMJ Global Health, International Health, JMIR Public Health, PLOS Global Health, BJPsych Open, Journal of Refugee Studies, British Journal of Sociology"
];

const grants = [
  { funder: "FCDO (Research Capacity & Communication)", amount: "£380,000", role: "PI", title: "Evidence-Informed Policymaking in FCAS", period: "2024–2026" },
  { funder: "FCDO (RCC)", amount: "£305,000", role: "PI", title: "AI in Agriculture: Evidence Synthesis", period: "2024–2026" },
  { funder: "FCDO (RCC)", amount: "£200,000", role: "PI", title: "Health Financing in FCAS", period: "2024–2026" },
  { funder: "NIHR", amount: "£150,000", role: "Co-I", title: "REDRESS: NTDs and Mental Health in Liberia", period: "2018–2022" },
  { funder: "UNHCR", amount: "£75,000", role: "Co-I", title: "Refugee Integration in National Health Systems", period: "2019–2021" },
];

const presentations = [
  "European Evaluation Society Conference (2025)",
  "3ie Evidence Week, Abu Dhabi (2024)",
  "Global Evidence Summit, Prague (2024)",
  "Campbell Collaboration Colloquium (2023)",
  "UKFIET Conference on Education and Development (2021)",
  "British Society of Gerontology Annual Conference (2021)",
  "Sociedad de Investigación Educativa Peruana (SIEP) Annual Conference (2015, 2016, 2017)",
];
---

<Layout title="CV">
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4">
      <div class="flex justify-between items-start mb-12">
        <div>
          <h1 class="text-4xl font-bold text-slate-900 mb-4">Curriculum Vitae</h1>
          <p class="text-xl text-slate-600">Academic and professional background</p>
        </div>
        <a href="/uploads/resume.pdf" class="px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition-colors flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
          </svg>
          Download PDF
        </a>
      </div>

      <!-- Experience -->
      <section class="mb-16">
        <h2 class="text-2xl font-bold text-slate-900 mb-8 pb-2 border-b border-slate-200">Professional Experience</h2>
        <div class="space-y-8">
          {experience.map(exp => (
            <div class="flex gap-6">
              <div class="flex-shrink-0 w-32 text-sm text-slate-500 font-medium">{exp.period}</div>
              <div>
                <h3 class="font-semibold text-slate-900">{exp.title}</h3>
                <div class="text-emerald-600 mb-2">{exp.organization}</div>
                <p class="text-slate-600 text-sm">{exp.description}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Teaching -->
      <section class="mb-16">
        <h2 class="text-2xl font-bold text-slate-900 mb-8 pb-2 border-b border-slate-200">Teaching</h2>
        <ul class="grid md:grid-cols-2 gap-3">
          {teaching.map(course => (
            <li class="flex items-start gap-2 text-slate-600">
              <svg class="w-5 h-5 text-emerald-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              {course}
            </li>
          ))}
        </ul>
      </section>

      <!-- Training -->
      <section class="mb-16">
        <h2 class="text-2xl font-bold text-slate-900 mb-8 pb-2 border-b border-slate-200">Advanced Training</h2>
        <ul class="space-y-2">
          {training.map(item => (
            <li class="text-slate-600">{item}</li>
          ))}
        </ul>
      </section>

      <!-- Service -->
      <section class="mb-16">
        <h2 class="text-2xl font-bold text-slate-900 mb-8 pb-2 border-b border-slate-200">Service & Editorial Work</h2>
        <ul class="space-y-2">
          {service.map(item => (
            <li class="text-slate-600">{item}</li>
          ))}
        </ul>
      </section>

      <!-- Grants -->
      <section class="mb-16">
        <h2 class="text-2xl font-bold text-slate-900 mb-8 pb-2 border-b border-slate-200">Grants & Funding</h2>
        <div class="space-y-6">
          {grants.map(grant => (
            <div class="flex gap-6">
              <div class="flex-shrink-0 w-32 text-sm text-slate-500 font-medium">{grant.period}</div>
              <div>
                <h3 class="font-semibold text-slate-900">{grant.title}</h3>
                <div class="text-emerald-600 text-sm">{grant.funder} · {grant.role} · {grant.amount}</div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Presentations -->
      <section class="mb-16">
        <h2 class="text-2xl font-bold text-slate-900 mb-8 pb-2 border-b border-slate-200">Selected Presentations</h2>
        <ul class="grid md:grid-cols-2 gap-3">
          {presentations.map(item => (
            <li class="flex items-start gap-2 text-slate-600">
              <svg class="w-5 h-5 text-emerald-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </section>

      <p class="text-sm text-slate-400 text-center">Last updated: February 2026</p>
    </div>
  </section>
</Layout>
