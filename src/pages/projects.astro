---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: "AI Ethics @ Governance Capacity",
    emoji: "🏛️",
    description: "Cross-national analysis of 2,216 AI policies across 193 countries. Four companion volumes on implementation capacity, ethics governance, UNESCO alignment, and shared methodology.",
    url: "/ai-governance-capacity/",
    repo: "https://github.com/lsempe77/ai-governance-capacity",
    tags: ["AI Ethics & Governance", "Policy Analysis", "LLMs"],
  },
  {
    title: "Manual de Metodología",
    emoji: "📖",
    description: "Spanish-language research methods textbook covering the complete research process — from formulating questions to writing results. Built around the mistakes students actually make.",
    url: "/metodos/",
    repo: "https://github.com/lsempe77/metodos",
    tags: ["Education", "Spanish", "Research Methods"],
  },
  {
    title: "Therapeutic Persona Monitoring",
    emoji: "🧠",
    description: "Activation-based monitoring system for mental health chatbots. Detects persona drift in model internals that text analysis misses — validated by clinical psychologists.",
    url: "https://github.com/lsempe77/mh_persona",
    repo: "https://github.com/lsempe77/mh_persona",
    tags: ["AI Safety", "Mental Health", "Activation Steering"],
  },
  {
    title: "Hypothesis Testing Visualisation",
    emoji: "📊",
    description: "Interactive React app for teaching statistical hypothesis testing concepts — p-values, power, effect sizes — through dynamic visualisation.",
    url: "https://github.com/lsempe77/hypothesis-visualization",
    repo: "https://github.com/lsempe77/hypothesis-visualization",
    tags: ["Education", "React", "Statistics"],
  },
  {
    title: "FCDO Policy Scraper",
    emoji: "🕸️",
    description: "Polite, rate-limited web scraper for FCDO research programme documents. Handles pagination, retries, and structured data extraction.",
    url: "https://github.com/lsempe77/fcdo-scraper",
    repo: "https://github.com/lsempe77/fcdo-scraper",
    tags: ["Python", "Data Collection", "Policy"],
  },
  {
    title: "QCA Health Systems",
    emoji: "🏥",
    description: "Qualitative Comparative Analysis of health system strengthening interventions. Crisp-set and fuzzy-set QCA with robustness checks.",
    url: "https://github.com/lsempe77/qca-health-systems",
    repo: "https://github.com/lsempe77/qca-health-systems",
    tags: ["Health", "QCA", "R"],
  },
  {
    title: "Shiny Study Review System",
    emoji: "🔍",
    description: "R Shiny application for collaborative systematic review screening — track progress, resolve conflicts, export decisions.",
    url: "https://github.com/lsempe77/shiny-synthesis",
    repo: "https://github.com/lsempe77/shiny-synthesis",
    tags: ["R", "Shiny", "Evidence Synthesis"],
  },
  {
    title: "R Course for Impact Evaluation",
    emoji: "📈",
    description: "Teaching materials for R programming in the context of impact evaluation — from data wrangling to regression and visualisation.",
    url: "https://github.com/lsempe77/R-course",
    repo: "https://github.com/lsempe77/R-course",
    tags: ["R", "Education", "Impact Evaluation"],
  },
  {
    title: "FCAS Research Chatbot",
    emoji: "🎙️",
    description: "Voice interface for research synthesis on fragile and conflict-affected states. RAG-powered chatbot with podcast-style output.",
    url: "https://github.com/lsempe77/fcas_chatbot_podcast",
    repo: "https://github.com/lsempe77/fcas_chatbot_podcast",
    tags: ["RAG", "Voice AI", "FCAS"],
  },
];
---

<Layout title="Projects">
  <section class="py-16 bg-gradient-to-br from-slate-900 via-slate-800 to-emerald-900 text-white">
    <div class="max-w-5xl mx-auto px-4">
      <h1 class="text-4xl font-bold mb-3">Projects</h1>
      <p class="text-slate-300 text-lg">Research tools, books, and open-source code.</p>
    </div>
  </section>

  <section class="py-12 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid gap-6 md:grid-cols-2">
        {projects.map(project => (
          <a href={project.url} target={project.url.startsWith('/') ? '_self' : '_blank'}
             class="block p-6 bg-white border border-slate-200 rounded-xl hover:border-emerald-400 hover:shadow-lg transition-all group">
            <div class="flex items-start gap-3 mb-3">
              <span class="text-2xl">{project.emoji}</span>
              <h2 class="text-lg font-semibold text-slate-900 group-hover:text-emerald-600 transition-colors">
                {project.title}
              </h2>
            </div>
            <p class="text-slate-600 text-sm leading-relaxed mb-4">{project.description}</p>
            <div class="flex flex-wrap gap-2">
              {project.tags.map(tag => (
                <span class="px-2 py-0.5 bg-slate-100 text-slate-600 rounded-full text-xs">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
